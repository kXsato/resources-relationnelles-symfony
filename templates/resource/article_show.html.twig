{% extends 'base.html.twig' %}

{% block title %}{{ article.title }}{% endblock %}

{% block body %}
<article class="container mt-5">
    <header class="mb-4">
        <h1 class="display-4">{{ article.title }}</h1>
        <p class="text-muted">Publié le {{ article.createdAt|date('d/m/Y') }} par {{ article.displayAuthor }}</p>
    </header>

    <hr>

    <div class="article-content mt-4">
        {{ article.content|raw }}
    </div>

    <footer class="mt-5 d-flex gap-3">
        <a href="{{ path('app_resource_list') }}" class="btn btn-outline-secondary">
            ← Retour aux ressources
        </a>

        {% if app.user %}
        <button id="btn-favorite" class="btn btn-outline-warning" data-article-id="{{ article.id }}">
            Mettre en favori
        </button>
        {% endif %}
    </footer>
</article>

<div class="container mt-5">
    <h2 class="fw-bold mb-4">💬 Commentaires</h2>

    {% if app.user %}
    <div class="mb-4">
        <textarea id="comment-input" class="form-control mb-2" rows="3" placeholder="Écrire un commentaire..."></textarea>
        <button id="btn-comment" class="btn btn-primary">Publier</button>
    </div>
    {% else %}
    <p class="text-muted"><a href="{{ path('app_login') }}">Connectez-vous</a> pour commenter.</p>
    {% endif %}

    <div id="flash-comment" class="mb-3"></div>
    <div id="comments-list"></div>
</div>

<script>
(function() {
const articleId = {{ article.id|json_encode|raw }};
const isLoggedIn = {{ app.user ? 'true' : 'false' }};
const isModerator = {{ is_granted('ROLE_MODERATOR') ? 'true' : 'false' }};

function renderComment(comment, depth = 0) {
    const margin = depth * 20;

    const deleteBtn = (comment.isOwner || isModerator)
        ? `<button onclick="deleteComment(${comment.id})" class="btn btn-sm btn-outline-danger ms-2">🗑 Supprimer</button>`
        : '';

    const replyBtn = isLoggedIn
        ? `<button onclick="showReplyForm(${comment.id})" class="btn btn-sm btn-outline-secondary ms-2">↩ Répondre</button>`
        : '';

    const reportBtn = isLoggedIn && !comment.isOwner
        ? `<button onclick="reportComment(${comment.id})" class="btn btn-sm btn-outline-warning ms-2">🚩 Signaler</button>`
        : '';

    const reportDetail = comment.reportCount > 0 && isModerator
        ? comment.reports.map(r => `${r.user} : ${r.motif}`).join(' / ')
        : '';

    const reportBadge = comment.reportCount > 0 && isModerator
        ? `<span class="badge bg-danger ms-2">⚠ ${comment.reportCount} signalement(s) — ${reportDetail}</span>`
        : '';

    let html = `
        <div class="card mb-2" style="margin-left: ${margin}px" id="comment-${comment.id}">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <strong>${comment.author}</strong>
                    <div class="text-end">
                        ${reportBadge}
                        <small class="text-muted ms-2">${comment.createdAt}</small>
                    </div>
                </div>
                <p class="mt-2 mb-1">${comment.content}</p>
                <div>
                    ${replyBtn}
                    ${reportBtn}
                    ${deleteBtn}
                </div>
                <div id="reply-form-${comment.id}" class="mt-2" style="display:none">
                    <textarea class="form-control mb-1" rows="2" placeholder="Votre réponse..."></textarea>
                    <button onclick="submitReply(${comment.id})" class="btn btn-sm btn-primary">Répondre</button>
                    <button onclick="hideReplyForm(${comment.id})" class="btn btn-sm btn-secondary ms-1">Annuler</button>
                </div>
            </div>
        </div>
    `;

    comment.children.forEach(child => {
        html += renderComment(child, depth + 1);
    });

    return html;
}

window.reportComment = function(commentId) {
    const motifs = {
        'inapproprie': 'Contenu inapproprié',
        'spam': 'Spam',
        'harcelement': 'Harcèlement',
        'fausse_info': 'Fausse information',
        'autre': 'Autre'
    };

    const motifKeys = Object.keys(motifs);
    const motifList = motifKeys.map((k, i) => `${i + 1}. ${motifs[k]}`).join('\n');
    const choix = prompt(`Choisissez un motif :\n${motifList}\n\nEntrez le numéro :`);

    if (!choix) return;
    const index = parseInt(choix) - 1;
    if (index < 0 || index >= motifKeys.length) {
        alert('Choix invalide');
        return;
    }

    const motif = motifKeys[index];

    fetch(`/comments/report/${commentId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ motif })
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'reported') {
            const flash = document.getElementById('flash-comment');
            flash.innerHTML = '<div class="alert alert-info">✅ Commentaire signalé. Un modérateur va l\'examiner.</div>';
            setTimeout(() => flash.innerHTML = '', 4000);
            loadComments();
        } else if (data.status === 'already_reported') {
            alert('Vous avez déjà signalé ce commentaire.');
        }
    });
};

window.deleteComment = function(commentId) {
    if (!confirm('Supprimer ce commentaire ?')) return;

    fetch(`/comments/delete/${commentId}`, { method: 'DELETE' })
        .then(r => r.json())
        .then(data => {
            if (data.status === 'deleted') {
                const card = document.getElementById(`comment-${commentId}`);
                if (card) card.remove();

                const flash = document.getElementById('flash-comment');
                flash.innerHTML = '<div class="alert alert-success">✅ Commentaire supprimé.</div>';
                setTimeout(() => flash.innerHTML = '', 3000);

                loadComments();
            }
        });
};

window.showReplyForm = function(commentId) {
    document.getElementById(`reply-form-${commentId}`).style.display = 'block';
};

window.hideReplyForm = function(commentId) {
    document.getElementById(`reply-form-${commentId}`).style.display = 'none';
};

window.submitReply = function(parentId) {
    const form = document.getElementById(`reply-form-${parentId}`);
    const content = form.querySelector('textarea').value.trim();
    if (!content) return;

    fetch('/comments/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content, resourceId: articleId, parentId })
    })
    .then(r => r.json())
    .then(() => {
        window.hideReplyForm(parentId);
        loadComments();
    });
};

function loadComments() {
    fetch(`/comments/resource/${articleId}`)
        .then(r => r.json())
        .then(comments => {
            const container = document.getElementById('comments-list');
            if (comments.length === 0) {
                container.innerHTML = '<p class="text-muted">Aucun commentaire pour le moment.</p>';
                return;
            }
            container.innerHTML = comments.map(c => renderComment(c)).join('');
        });
}

const btnComment = document.getElementById('btn-comment');
if (btnComment) {
    btnComment.addEventListener('click', function () {
        const content = document.getElementById('comment-input').value.trim();
        if (!content) return;

        fetch('/comments/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content, resourceId: articleId })
        })
        .then(r => r.json())
        .then(() => {
            document.getElementById('comment-input').value = '';
            loadComments();
        });
    });
}

const btn = document.getElementById('btn-favorite');
if (btn) {
    const articleId2 = btn.dataset.articleId;
    fetch('/favorites/list')
        .then(r => r.json())
        .then(favorites => {
            const isFav = favorites.some(f => f.id == articleId2);
            btn.textContent = isFav ? '★ Retirer des favoris' : 'Mettre en favori';
            btn.classList.toggle('btn-warning', isFav);
            btn.classList.toggle('btn-outline-warning', !isFav);
        });

    btn.addEventListener('click', function () {
        fetch(`/favorites/toggle/${articleId2}`, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.json())
        .then(data => {
            if (data.status === 'added') {
                btn.textContent = '★ Retirer des favoris';
                btn.classList.replace('btn-outline-warning', 'btn-warning');
            } else {
                btn.textContent = 'Mettre en favori';
                btn.classList.replace('btn-warning', 'btn-outline-warning');
            }
        });
    });
}

loadComments();
})();
</script>
{% endblock %}