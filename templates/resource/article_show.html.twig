{% extends 'base.html.twig' %}

{% block title %}{{ article.title }}{% endblock %}

{% block body %}
    <article class="container mt-5">
        <header class="mb-4">
            {# <span class="badge bg-primary">{{ article.category ? article.category.name : 'Général' }}</span> #}
            <h1 class="display-4">{{ article.title }}</h1>
            <p class="text-muted">Publié le {{ article.createdAt|date('d/m/Y') }} par {{ article.displayAuthor }}</p>
        </header>

        <hr>

        <div class="article-content mt-4">
            {# Le filtre |raw est INDISPENSABLE pour le contenu TinyMCE #}
            {{ article.content|raw }}
        </div>

        <footer class="mt-5">
            {# <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">Retour à l'accueil</a> #}
        </footer>
    </article>
{% endblock %}