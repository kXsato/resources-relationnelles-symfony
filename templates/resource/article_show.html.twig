{% extends 'base.html.twig' %}

{% block title %}{{ article.title }}{% endblock %}

{% block body %}
<article class="container mt-5">
    <header class="mb-4">
        <h1 class="display-4">{{ article.title }}</h1>
        <p class="text-muted">Publié le {{ article.createdAt|date('d/m/Y') }}</p>
    </header>

    <hr>

    <div class="article-content mt-4">
        {{ article.content|raw }}
    </div>

    <footer class="mt-5 d-flex gap-3">
        <a href="{{ path('app_resource_list') }}" class="btn btn-outline-secondary">
            ← Retour aux ressources
        </a>

        {% if app.user %}
        <button id="btn-favorite"
                class="btn btn-outline-warning"
                data-article-id="{{ article.id }}">
            Mettre en favori
        </button>
        {% endif %}
    </footer>
</article>

<script>
const btn = document.getElementById('btn-favorite');

if (btn) {
    const articleId = btn.dataset.articleId;

    fetch('/favorites/list')
        .then(r => r.json())
        .then(favorites => {
            const isFav = favorites.some(f => f.id == articleId);
            btn.textContent = isFav ? '★ Retirer des favoris' : 'Mettre en favori';
            btn.classList.toggle('btn-warning', isFav);
            btn.classList.toggle('btn-outline-warning', !isFav);
        });

    btn.addEventListener('click', function () {
        fetch(`/favorites/toggle/${articleId}`, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.json())
        .then(data => {
            if (data.status === 'added') {
                btn.textContent = '★ Retirer des favoris';
                btn.classList.replace('btn-outline-warning', 'btn-warning');
            } else {
                btn.textContent = 'Mettre en favori';
                btn.classList.replace('btn-warning', 'btn-outline-warning');
            }
        });
    });
}
</script>
{% endblock %}