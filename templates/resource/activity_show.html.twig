{% extends 'base.html.twig' %}

{% block title %}{{ article.title }}{% endblock %}

{% block body %}
<div class="flex flex-col min-h-screen w-full">

{# Skip navigation (RGAA) #}
<a href="#activity-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 btn btn-primary btn-sm z-50">
    Aller au contenu
</a>

{# ── Breadcrumbs ──────────────────────────────────────────────────────────── #}
<nav aria-label="Fil d'Ariane" class="container mx-auto px-4 pt-4">
    <div class="breadcrumbs text-sm">
        <ul>
            <li><a href="/">Accueil</a></li>
            <li><a href="{{ path('app_resource_list') }}">Ressources</a></li>
            <li aria-current="page">
                <span class="inline-block max-w-[40vw] truncate align-bottom">{{ article.title }}</span>
            </li>
        </ul>
    </div>
</nav>

{# ── Hero ─────────────────────────────────────────────────────────────────── #}
<div class="hero bg-gradient-to-br from-primary/10 via-base-200 to-secondary/10 py-10 md:py-20" role="banner">
    <div class="hero-content text-center max-w-2xl w-full px-4">
        <div class="w-full">
            <div class="flex flex-wrap justify-center gap-2 mb-5">
                <span class="badge badge-secondary badge-lg gap-1">🎯 Activité</span>
                {% if article.categories is not empty %}
                    {% for category in article.categories %}
                        <span class="badge badge-primary badge-lg">{{ category.name }}</span>
                    {% endfor %}
                {% endif %}
            </div>

            <h1 class="text-2xl sm:text-3xl md:text-5xl font-extrabold mb-5 break-words leading-tight">
                {{ article.title }}
            </h1>

            <p class="text-base-content/60 text-sm sm:text-base">
                Publié le
                <time datetime="{{ article.createdAt|date('Y-m-d') }}">{{ article.createdAt|date('d/m/Y') }}</time>
                par <span class="font-semibold text-base-content/80">{{ article.displayAuthor }}</span>
            </p>
        </div>
    </div>
</div>

{# ── Infos activité ───────────────────────────────────────────────────────── #}
<div class="container mx-auto px-4 py-8 max-w-3xl">
    {% if article.gameType or article.startDate or article.endDate %}
    <div class="stats stats-vertical sm:stats-horizontal shadow w-full bg-base-200 rounded-2xl mb-8">
        {% if article.gameType %}
        <div class="stat place-items-center">
            <div class="stat-figure text-primary text-3xl">🎮</div>
            <div class="stat-title">Type de jeu</div>
            <div class="stat-value text-primary text-lg">{{ article.gameType|capitalize }}</div>
        </div>
        {% endif %}
        {% if article.startDate %}
        <div class="stat place-items-center">
            <div class="stat-figure text-secondary text-3xl">📅</div>
            <div class="stat-title">Date de début</div>
            <div class="stat-value text-secondary text-lg">{{ article.startDate|date('d/m/Y') }}</div>
        </div>
        {% endif %}
        {% if article.endDate %}
        <div class="stat place-items-center">
            <div class="stat-figure text-accent text-3xl">🏁</div>
            <div class="stat-title">Date de fin</div>
            <div class="stat-value text-accent text-lg">{{ article.endDate|date('d/m/Y') }}</div>
        </div>
        {% endif %}
    </div>
    {% endif %}
</div>

{# ── Contenu de l'activité ────────────────────────────────────────────────── #}
<main id="main-content">
    <article class="container mx-auto px-4 pb-6 md:pb-10 max-w-3xl" aria-labelledby="activity-heading">
        <h2 id="activity-heading" class="sr-only">Contenu de l'activité</h2>

        <div id="activity-content" class="prose prose-sm sm:prose-base md:prose-lg max-w-none">
            {{ article.content|raw }}
        </div>

        <div class="flex flex-col sm:flex-row gap-3 mt-8 md:mt-10" role="group" aria-label="Actions sur l'activité">
            <a href="{{ path('app_resource_list') }}" class="btn btn-outline btn-neutral w-full sm:w-auto">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Retour aux ressources
            </a>
        </div>
    </article>
</main>

{# ── Quiz ─────────────────────────────────────────────────────────────────── #}
{% if article.gameType == 'quiz' and article.questions is not empty %}
<div class="container mx-auto px-4 py-10 max-w-3xl" id="quiz-section">

    <div class="divider divider-primary text-xl font-bold mb-8">
        <span class="flex items-center gap-2">🧠 Quiz</span>
    </div>

    {% if article.endDate and article.endDate < now %}
    {# ── Quiz expiré ── #}
    <div role="alert" class="alert alert-error shadow-lg rounded-2xl">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
            <h3 class="font-bold">Activité terminée</h3>
            <div class="text-sm">Cette activité s'est clôturée le {{ article.endDate|date('d/m/Y') }}.</div>
        </div>
    </div>
    <a href="{{ path('app_resource_list') }}" class="btn btn-outline btn-neutral btn-sm mt-4">← Retour aux ressources</a>

    {% elseif app.user %}
    {# ── Quiz connecté ── #}
    <div id="quiz-container">

        {# ── Écran de démarrage ── #}
        <div id="quiz-start">
            <div class="card bg-base-100 shadow-xl border border-primary/20 rounded-3xl overflow-hidden">
                <div class="card-body items-center text-center gap-6 py-12 px-8">
                    <div class="text-6xl animate-bounce">🧠</div>
                    <h3 class="card-title text-2xl font-extrabold">Prêt à relever le défi ?</h3>
                    <p class="text-base-content/60 max-w-sm">
                        Ce quiz contient <span class="badge badge-primary badge-lg font-bold">{{ article.questions|length }} question(s)</span>.
                        Sélectionne la meilleure réponse pour chacune.
                    </p>

                    {# Steps indicatifs #}
                    <ul class="steps steps-horizontal w-full max-w-xs text-xs mt-2" id="quiz-steps-preview">
                        {% for i in 1..article.questions|length %}
                        <li class="step {% if loop.first %}step-primary{% endif %}"></li>
                        {% endfor %}
                    </ul>

                    <button onclick="startQuiz()" class="btn btn-primary btn-lg gap-2 rounded-2xl mt-2 px-10">
                        🚀 Commencer le quiz
                    </button>
                </div>
            </div>
        </div>

        {# ── Questions ── #}
        <div id="quiz-questions" class="hidden">
            {# Barre de progression en haut #}
            <div class="flex items-center justify-between mb-3">
                <span id="quiz-progress-label" class="text-sm font-semibold text-base-content/60">Question 1 / ?</span>
                <span id="quiz-progress-pct" class="text-sm font-bold text-primary">0%</span>
            </div>
            <progress id="quiz-progress-bar" class="progress progress-primary w-full mb-6 h-3 rounded-full" value="0" max="100"></progress>

            {# Steps horizontaux #}
            <ul class="steps steps-horizontal w-full mb-8 text-xs" id="quiz-steps">
                {% for q in article.questions %}
                <li class="step" id="step-{{ loop.index0 }}"></li>
                {% endfor %}
            </ul>

            {# Carte de la question courante #}
            <div id="quiz-question-card"></div>
        </div>

        {# ── Résultats ── #}
        <div id="quiz-result" class="hidden"></div>

    </div>

    {% else %}
    {# ── Non connecté ── #}
    <div role="alert" class="alert alert-info shadow-lg rounded-2xl">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="h-6 w-6 shrink-0 stroke-current">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <div>
            <h3 class="font-bold">Connexion requise</h3>
            <div class="text-sm">
                <a href="{{ path('app_login') }}" class="link link-primary font-bold">Connectez-vous</a> pour participer au quiz.
            </div>
        </div>
    </div>
    {% endif %}
</div>
{% endif %}

{# ── Chat ─────────────────────────────────────────────────────────────────── #}
<div class="container mx-auto px-4 py-10 max-w-3xl">
    <h2 class="text-2xl font-bold mb-6">💬 Discussion</h2>

    {% if app.user %}
    <div class="mb-6">
        <textarea
            class="w-full border border-gray-300 
            focus:border-gray-400 focus:outline-none focus:ring-0
            outline-none shadow-none p-2"
            style="border-radius: 14px;"
            rows="2"
            placeholder="Participer à la discussion..."></textarea>
        <button id="btn-comment" class="btn btn-primary btn-sm mt-2">📝 Envoyer</button>
    </div>
    {% else %}
    <div role="alert" class="alert alert-info mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="h-6 w-6 shrink-0 stroke-current">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="text-black">👋 <a href="{{ path('app_login') }}" class="underline font-bold">Connectez-vous</a> pour participer à la discussion.</span>
    </div>
    {% endif %}

    <div id="flash-comment" class="mb-4"></div>
    <div id="comments-list"></div>
</div>

{# ── Activités similaires ─────────────────────────────────────────────────── #}
{% if relatedArticles is defined and relatedArticles is not empty %}
<section class="bg-gradient-to-br from-base-200 to-base-300 py-14 mt-4 mb-5" aria-labelledby="related-heading">
    <div class="container mx-auto px-4">
        <h2 id="related-heading" class="text-2xl font-extrabold mb-8 flex items-center gap-2">
            ✨ À découvrir aussi
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" role="list">
            {% for related in relatedArticles %}
            <div class="card bg-base-100 shadow-md hover:shadow-xl transition-all hover:-translate-y-1 duration-200 rounded-2xl" role="listitem">
                <div class="card-body gap-2">
                    {% if related.categories is not empty %}
                    <div class="flex flex-wrap gap-1 mb-1" aria-label="Catégories">
                        {% for cat in related.categories %}
                            <span class="badge badge-ghost badge-sm">{{ cat.name }}</span>
                        {% endfor %}
                    </div>
                    {% endif %}

                    <h3 class="card-title text-base line-clamp-2">{{ related.title }}</h3>

                    {% if related.description %}
                    <p class="text-base-content/60 text-sm line-clamp-3">{{ related.description }}</p>
                    {% endif %}

                    <p class="text-xs text-base-content/40 mt-1">
                        <time datetime="{{ related.createdAt|date('Y-m-d') }}">{{ related.createdAt|date('d/m/Y') }}</time>
                        · {{ related.displayAuthor }}
                    </p>

                    <div class="card-actions justify-end mt-3">
                        <a href="{{ path('app_resource_show', {id: related.id}) }}"
                           class="btn btn-primary btn-sm rounded-xl"
                           aria-label="Voir l'activité : {{ related.title }}">
                            Voir l'activité →
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ── Progression (fixe bas-droite) ───────────────────────────────────────── #}
{# ── Progression (fixe bas-droite) ───────────────────────────────────────── #}
<div id="reading-progress-widget"
     style="position:fixed; bottom:1rem; right:1rem; z-index:1000;"
     data-progress-id="{{ progress ? progress.id : '' }}"
     data-read-percentage="{{ progress ? progress.readPercentage : 0 }}"
     aria-live="polite"
     aria-atomic="true"
     aria-label="Progression">
    <div id="radial-progress"
         class="radial-progress text-primary"
         style="--value:{{ progress ? progress.readPercentage : 0 }};"
         aria-valuenow="{{ progress ? progress.readPercentage : 0 }}"
         aria-valuemin="0"
         aria-valuemax="100"
         role="progressbar"
         aria-label="Progression : {{ progress ? progress.readPercentage : 0 }}%">
        {{ progress ? progress.readPercentage : 0 }}%
    </div>
</div>

</div>{# /flex flex-col #}

<script>
(function () {
const articleId = {{ article.id|json_encode|raw }};
const isLoggedIn = {{ app.user ? 'true' : 'false' }};
const isModerator = {{ is_granted('ROLE_MODERATOR') ? 'true' : 'false' }};

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//  QUIZ
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
let quizQuestions = [];
let currentQuestion = 0;
let userAnswers = {};

window.startQuiz = function () {
    fetch(`/quiz/questions/{{ article.id }}`)
        .then(r => r.json())
        .then(questions => {
            quizQuestions = questions;
            currentQuestion = 0;
            userAnswers = {};
            document.getElementById('quiz-start').classList.add('hidden');
            document.getElementById('quiz-questions').classList.remove('hidden');
            renderSteps();
            showQuestion();
        });
};

function renderSteps() {
    const steps = document.getElementById('quiz-steps');
    if (!steps) return;
    steps.innerHTML = quizQuestions
        .map((_, i) => `<li class="step text-xs" id="step-${i}" data-content="${i + 1}"></li>`)
        .join('');
}

function updateProgress() {
    const total = quizQuestions.length;
    const pct = Math.round((currentQuestion / total) * 100);
    const bar = document.getElementById('quiz-progress-bar');
    const pctEl = document.getElementById('quiz-progress-pct');
    const label = document.getElementById('quiz-progress-label');
    if (bar) bar.value = pct;
    if (pctEl) pctEl.textContent = pct + '%';
    if (label) label.textContent = `Question ${currentQuestion + 1} / ${total}`;

    // Colorer les steps complétés
    for (let i = 0; i < total; i++) {
        const s = document.getElementById(`step-${i}`);
        if (!s) continue;
        s.classList.remove('step-primary', 'step-success', 'step-warning');
        if (i < currentQuestion) s.classList.add('step-success');
        else if (i === currentQuestion) s.classList.add('step-primary');
    }
}

function showQuestion() {
    const q = quizQuestions[currentQuestion];
    const total = quizQuestions.length;
    const isLast = currentQuestion + 1 === total;
    updateProgress();

    const card = document.getElementById('quiz-question-card');
    card.innerHTML = `
        <div class="card bg-base-100 shadow-xl border border-primary/20 rounded-3xl overflow-hidden animate-fade-in">
            <div class="card-body gap-5 py-8 px-6 md:px-10">

                <div class="flex items-center gap-3">
                    <div class="badge badge-primary badge-lg font-bold">${currentQuestion + 1} / ${total}</div>
                    ${isLast ? '<div class="badge badge-warning badge-outline badge-sm">Dernière question !</div>' : ''}
                </div>

                <p class="text-lg md:text-xl font-bold leading-snug">${q.question}</p>

                <div class="flex flex-col gap-3 mt-2" id="options-group">
                    ${[
                        { val: 1, text: q.propositionA },
                        { val: 2, text: q.propositionB },
                        { val: 3, text: q.propositionC },
                    ].map(opt => `
                        <label class="quiz-option flex items-center gap-4 cursor-pointer p-4 rounded-2xl border-2 border-base-300 bg-base-50 hover:border-primary hover:bg-primary/5 transition-all duration-150 select-none"
                               data-val="${opt.val}">
                            <input type="radio" name="answer" value="${opt.val}" class="radio radio-primary radio-sm shrink-0" />
                            <span class="text-sm md:text-base">${opt.text}</span>
                        </label>
                    `).join('')}
                </div>

                <div class="card-actions justify-between items-center mt-2">
                    <span class="text-xs text-base-content/40">Sélectionne une réponse pour continuer</span>
                    <button onclick="nextQuestion(${q.id})"
                            class="btn btn-primary gap-2 rounded-2xl px-8"
                            id="btn-next">
                        ${isLast ? '🏁 Terminer le quiz' : 'Suivant →'}
                    </button>
                </div>
            </div>
        </div>
    `;

    // Highlight au clic
    card.querySelectorAll('.quiz-option').forEach(label => {
        label.addEventListener('click', () => {
            card.querySelectorAll('.quiz-option').forEach(l => {
                l.classList.remove('border-primary', 'bg-primary/10');
            });
            label.classList.add('border-primary', 'bg-primary/10');
        });
    });
}

window.nextQuestion = function (questionId) {
    const selected = document.querySelector('input[name="answer"]:checked');
    if (!selected) {
        // Toast d'erreur
        showToast('⚠ Veuillez sélectionner une réponse.', 'alert-warning');
        return;
    }

    // Marquer l'étape comme réussie
    const step = document.getElementById(`step-${currentQuestion}`);
    if (step) { step.classList.remove('step-primary'); step.classList.add('step-success'); }

    userAnswers[questionId] = parseInt(selected.value);
    currentQuestion++;

    if (currentQuestion < quizQuestions.length) {
        showQuestion();
    } else {
        // Mettre à 100% avant de soumettre
        const bar = document.getElementById('quiz-progress-bar');
        if (bar) bar.value = 100;
        document.getElementById('quiz-progress-pct').textContent = '100%';
        submitQuiz();
    }
};

function submitQuiz() {
    document.getElementById('quiz-question-card').innerHTML = `
        <div class="flex flex-col items-center gap-4 py-12">
            <span class="loading loading-spinner loading-lg text-primary"></span>
            <p class="text-base-content/60 text-sm">Calcul de votre score…</p>
        </div>`;

    fetch(`/quiz/answer/{{ article.id }}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ answers: userAnswers })
    })
    .then(r => r.json())
    .then(data => {
        document.getElementById('quiz-questions').classList.add('hidden');
        const result = document.getElementById('quiz-result');
        result.classList.remove('hidden');

        const percent = Math.round((data.score / data.total) * 100);
        const isSuccess = percent >= 50;
        const alertType = percent >= 80 ? 'alert-success' : percent >= 50 ? 'alert-warning' : 'alert-error';
        const iconColor = percent >= 80 ? '#22c55e' : percent >= 50 ? '#f59e0b' : '#ef4444';
        const msg = percent >= 80
            ? 'Excellent travail ! Tu maîtrises le sujet.'
            : percent >= 50
            ? 'Bien joué ! Encore un peu de pratique.'
            : 'Continue tes efforts, tu vas y arriver !';

        // Icône SVG : trophée si >= 50%, croix si < 50%
        const iconSvg = isSuccess
            ? `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="120" height="120" fill="none">
                  <!-- Coupe -->
                  <path d="M20 8 h24 v20 a12 12 0 0 1 -24 0 Z" fill="${iconColor}" opacity="0.9"/>
                  <!-- Anses -->
                  <path d="M20 12 Q8 12 8 22 Q8 30 20 30" stroke="${iconColor}" stroke-width="3.5" stroke-linecap="round" fill="none"/>
                  <path d="M44 12 Q56 12 56 22 Q56 30 44 30" stroke="${iconColor}" stroke-width="3.5" stroke-linecap="round" fill="none"/>
                  <!-- Pied -->
                  <rect x="28" y="28" width="8" height="12" rx="2" fill="${iconColor}"/>
                  <!-- Base -->
                  <rect x="20" y="40" width="24" height="5" rx="2.5" fill="${iconColor}"/>
                  <!-- Étoile -->
                  <text x="32" y="25" text-anchor="middle" font-size="12" fill="white" font-weight="bold">★</text>
               </svg>`
            : `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="120" height="120" fill="none">
                  <circle cx="32" cy="32" r="28" fill="${iconColor}" opacity="0.15"/>
                  <circle cx="32" cy="32" r="28" stroke="${iconColor}" stroke-width="3"/>
                  <line x1="20" y1="20" x2="44" y2="44" stroke="${iconColor}" stroke-width="5" stroke-linecap="round"/>
                  <line x1="44" y1="20" x2="20" y2="44" stroke="${iconColor}" stroke-width="5" stroke-linecap="round"/>
               </svg>`;

        result.innerHTML = `
            <div class="card bg-base-100 shadow-2xl border border-base-300 rounded-3xl overflow-hidden">
                <div class="card-body items-center text-center gap-6 py-12 px-8">
                    <h3 class="text-3xl font-extrabold">Quiz terminé !</h3>

                    <div class="flex items-center justify-center">${iconSvg}</div>

                    <div role="alert" class="alert ${alertType} rounded-2xl w-full max-w-sm">
                        <span class="font-medium">${msg}</span>
                    </div>

                    <div class="stats stats-horizontal shadow bg-base-200 rounded-2xl w-full max-w-xs">
                        <div class="stat place-items-center">
                            <div class="stat-title text-xs">Bonnes réponses</div>
                            <div class="stat-value text-success">${data.score}</div>
                        </div>
                        <div class="stat place-items-center">
                            <div class="stat-title text-xs">Mauvaises réponses</div>
                            <div class="stat-value text-error">${data.total - data.score}</div>
                        </div>
                        <div class="stat place-items-center">
                            <div class="stat-title text-xs">Total</div>
                            <div class="stat-value">${data.total}</div>
                        </div>
                    </div>

                    <button onclick="restartQuiz()" class="btn btn-outline btn-primary gap-2 rounded-2xl">
                        🔄 Recommencer
                    </button>
                </div>
            </div>
        `;
    });
}

window.restartQuiz = function () {
    document.getElementById('quiz-result').classList.add('hidden');
    document.getElementById('quiz-questions').classList.add('hidden');
    document.getElementById('quiz-start').classList.remove('hidden');
    userAnswers = {};
    currentQuestion = 0;
};

// ── Chat ──────────────────────────────────────────────────────────────────
function renderComment(comment, depth = 0) {
    const marginLeft = depth * 24;
    const chatAlign = depth % 2 === 1 ? 'chat-end' : 'chat-start';

    const deleteBtn = (comment.isOwner || isModerator)
        ? `<button onclick="deleteComment(${comment.id})" class="btn btn-xs btn-error btn-outline">🗑 Supprimer</button>`
        : '';

    const replyBtn = isLoggedIn
        ? `<button onclick="showReplyForm(${comment.id})" class="btn btn-xs btn-outline">↩ Répondre</button>`
        : '';

    const reportBtn = isLoggedIn && !comment.isOwner
        ? `<button onclick="reportComment(${comment.id})" class="btn btn-xs btn-warning btn-outline">🚩 Signaler</button>`
        : '';

    const resetReportsBtn = isModerator && comment.reportCount > 0
        ? `<button onclick="resetReports(${comment.id})" class="btn btn-xs btn-outline">🧹 Supprimer le signalement</button>`
        : '';

    const reportDetail = comment.reportCount > 0 && isModerator
        ? comment.reports.map(r => `<b>${r.user}</b> : ${r.motif}`).join(' / ')
        : '';

    const reportAlert = comment.reportCount > 0 && isModerator
        ? `<div role="alert" class="alert alert-warning py-2 px-3 text-sm mb-2">
               <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
               </svg>
               <span class="text-black">⚠ ${comment.reportCount} signalement(s) — ${reportDetail}</span>
           </div>`
        : '';

    let html = `
        <div style="margin-left: ${marginLeft}px" id="comment-${comment.id}" class="mb-4">
            ${reportAlert}
            <div class="chat ${chatAlign}">
                <div class="chat-header mb-1">
                    <span class="font-bold">${comment.author}</span>
                    <time class="text-xs opacity-50 ml-2">${comment.createdAt}</time>
                </div>
                <div class="chat-bubble ${comment.isOwner ? 'chat-bubble-primary' : ''}">
                    ${comment.content}
                </div>
                <div class="chat-footer mt-1 flex gap-1 flex-wrap">
                    ${replyBtn}
                    ${reportBtn}
                    ${resetReportsBtn}
                    ${deleteBtn}
                </div>
            </div>
            <div id="reply-form-${comment.id}" class="mt-2 ml-4" style="display:none">
                <textarea
                    class="w-full border border-gray-300 
                    focus:border-gray-400 focus:outline-none focus:ring-0
                    outline-none shadow-none p-2"
                    style="border-radius: 14px;"
                    rows="2"
                    placeholder="Votre réponse..."></textarea>
                <div class="flex gap-2">
                    <button onclick="submitReply(${comment.id})" class="btn btn-xs btn-primary">Répondre</button>
                    <button onclick="hideReplyForm(${comment.id})" class="btn btn-xs btn-ghost">Annuler</button>
                </div>
            </div>
        </div>
    `;

    comment.children.forEach(child => {
        html += renderComment(child, depth + 1);
    });

    return html;
}

window.reportComment = function(commentId) {
    const motifs = {
        'inapproprie': 'Contenu inapproprié',
        'spam': 'Spam',
        'harcelement': 'Harcèlement',
        'fausse_info': 'Fausse information',
        'autre': 'Autre'
    };

    const motifKeys = Object.keys(motifs);
    const motifList = motifKeys.map((k, i) => `${i + 1}. ${motifs[k]}`).join('\n');
    const choix = prompt(`Choisissez un motif :\n${motifList}\n\nEntrez le numéro :`);

    if (!choix) return;
    const index = parseInt(choix) - 1;
    if (index < 0 || index >= motifKeys.length) {
        alert('Choix invalide');
        return;
    }

    const motif = motifKeys[index];

    fetch(`/comments/report/${commentId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ motif })
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'reported') {
            const flash = document.getElementById('flash-comment');
            flash.innerHTML = `<div role="alert" class="alert alert-success mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>✅ Message signalé. Un modérateur va l'examiner.</span>
            </div>`;
            setTimeout(() => flash.innerHTML = '', 4000);
            loadComments();
        } else if (data.status === 'already_reported') {
            const flash = document.getElementById('flash-comment');
            flash.innerHTML = `<div role="alert" class="alert alert-warning mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                <span class="text-black">⚠ Vous avez déjà signalé ce message.</span>
            </div>`;
            setTimeout(() => flash.innerHTML = '', 4000);
        }
    });
};

window.resetReports = function(commentId) {
    if (!confirm('Supprimer tous les signalements de ce message ?')) return;

    fetch(`/comments/reset-reports/${commentId}`, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'reset') {
            const flash = document.getElementById('flash-comment');
            flash.innerHTML = `<div role="alert" class="alert alert-success mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>✅ Signalements supprimés.</span>
            </div>`;
            setTimeout(() => flash.innerHTML = '', 3000);
            loadComments();
        }
    });
};

window.deleteComment = function(commentId) {
    if (!confirm('Supprimer ce message ?')) return;

    fetch(`/comments/delete/${commentId}`, { method: 'DELETE' })
        .then(r => r.json())
        .then(data => {
            if (data.status === 'deleted') {
                const flash = document.getElementById('flash-comment');
                flash.innerHTML = `<div role="alert" class="alert alert-success mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>✅ Message supprimé.</span>
                </div>`;
                setTimeout(() => flash.innerHTML = '', 3000);
                loadComments();
            }
        });
};

window.showReplyForm = function(commentId) {
    document.getElementById(`reply-form-${commentId}`).style.display = 'block';
};

window.hideReplyForm = function(commentId) {
    document.getElementById(`reply-form-${commentId}`).style.display = 'none';
};

window.submitReply = function(parentId) {
    const form = document.getElementById(`reply-form-${parentId}`);
    const content = form.querySelector('textarea').value.trim();
    if (!content) return;

    fetch('/comments/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content, resourceId: articleId, parentId })
    })
    .then(r => r.json())
    .then(() => {
        window.hideReplyForm(parentId);
        loadComments();
    });
};

function loadComments() {
    fetch(`/comments/resource/${articleId}`)
        .then(r => r.json())
        .then(comments => {
            const container = document.getElementById('comments-list');
            if (comments.length === 0) {
                container.innerHTML = `<div role="alert" class="alert">
                    <span>Aucun message pour le moment. Soyez le premier à participer !</span>
                </div>`;
                return;
            }
            container.innerHTML = comments.map(c => renderComment(c)).join('');
        });
}

const btnComment = document.getElementById('btn-comment');
if (btnComment) {
    btnComment.addEventListener('click', function () {
        const content = document.getElementById('comment-input').value.trim();
        if (!content) return;

        fetch('/comments/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content, resourceId: articleId })
        })
        .then(r => r.json())
        .then(() => {
            document.getElementById('comment-input').value = '';
            loadComments();
        });
    });
}

loadComments();
})();
</script>

<script src="{{ asset('js/article_show.js') }}"></script>
{% endblock %}
