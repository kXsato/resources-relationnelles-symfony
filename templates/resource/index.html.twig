{% extends 'base.html.twig' %}

{% block title %}Toutes les ressources{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4 text-center">Découvrez nos ressources</h1>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for resource in resources %}
            <div class="col">
                <div class="card h-100 shadow-sm">
                    
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge bg-info text-dark">{{ resource.category.name|default('Général') }}</span>
                            {# Petit indicateur de type (Article, Game, etc.) #}
                            <small class="text-muted">
                                {% if resource is instance of 'App\\Entity\\Article' %}📄 Article
                                {% elseif resource is instance of 'App\\Entity\\MiniGame' %}🎮 Jeu
                                {% endif %}
                            </small>
                        </div>
                        
                        <h5 class="card-title">{{ resource.title }}</h5>
                        <p class="card-text text-muted">
                            {{ resource.description|u.truncate(80, '...')|default('Découvrez cette ressource passionnante !') }}
                        </p>
                    </div>

                    <div class="card-footer bg-transparent border-top-0 pb-3">
                        {# Le lien vers la page de détails qu'on a créée avant #}
                        <a href="{{ path('app_resource', {id: resource.id}) }}" class="btn btn-primary w-100">
                            Consulter
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <p class="text-center">Aucune ressource n'est disponible pour le moment.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}