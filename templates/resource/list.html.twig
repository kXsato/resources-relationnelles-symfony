{% extends 'base.html.twig' %}

{% block title %}Articles{% endblock %}

{% block body %}
<div class="flex flex-col w-full">

{# ── Breadcrumbs ──────────────────────────────────────────────────────────── #}
<nav aria-label="Fil d'Ariane" class="container mx-auto px-4 pt-4">
    <div class="breadcrumbs text-sm">
        <ul>
            <li><a href="/">Accueil</a></li>
            <li aria-current="page">Articles</li>
        </ul>
    </div>
</nav>

{# ── Header ───────────────────────────────────────────────────────────────── #}
<header class="bg-base-200 py-10 text-center">
    <h1 class="text-3xl sm:text-4xl font-bold mb-2">Découvrez nos ressources</h1>
    <p class="text-base-content/60 text-sm sm:text-base">Articles et contenus pour enrichir vos relations</p>
</header>

<div class="container mx-auto px-4 py-6">

    {# ── Filtres par catégorie ─────────────────────────────────────────────── #}
    <nav aria-label="Filtrer par catégorie" class="flex flex-wrap gap-2 justify-center mb-8">
        <a href="{{ path('app_resource_list') }}"
           class="badge badge-lg {{ currentCategoryId is null ? 'badge-primary' : 'badge-neutral badge-outline' }}"
           {% if currentCategoryId is null %}aria-current="true"{% endif %}>
            Toutes
        </a>
        {% for category in categories %}
            <a href="{{ path('app_resource_list', { category: category.id }) }}"
               class="badge badge-lg {{ currentCategoryId == category.id ? 'badge-primary' : 'badge-neutral badge-outline' }}"
               {% if currentCategoryId == category.id %}aria-current="true"{% endif %}>
                {{ category.name }}
            </a>
        {% endfor %}
    </nav>

    {# ── Grille de cards ───────────────────────────────────────────────────── #}
    {% if resources is empty %}
        <div class="text-center py-16">
            <p class="text-base-content/50 text-lg">Aucune ressource n'est disponible pour le moment.</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for resource in resources %}
                <article class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow h-full">
                    <div class="card-body flex flex-col">

                        <div class="flex items-center justify-between mb-2">
                            {% set type = resource.resourceType %}
                            {% if type == 'article' %}
                                <span class="badge badge-primary badge-sm">📄 Article</span>
                            {% elseif type == 'activity' %}
                                <span class="badge badge-secondary badge-sm">🎯 Activité</span>
                            {% elseif type == 'video' %}
                                <span class="badge badge-error badge-sm">🎬 Vidéo</span>
                            {% elseif type == 'game' %}
                                <span class="badge badge-success badge-sm">🎮 Jeu</span>
                            {% else %}
                                <span class="badge badge-neutral badge-sm">{{ type|capitalize }}</span>
                            {% endif %}
                            <time class="text-xs text-base-content/40" datetime="{{ resource.createdAt|date('Y-m-d') }}">
                                {{ resource.createdAt|date('d/m/Y') }}
                            </time>
                        </div>

                        <h2 class="font-semibold leading-snug line-clamp-2 mb-2">
                            {{ resource.title }}
                        </h2>

                        {% set desc = resource.description|default('Découvrez cette ressource !') %}
                        <p class="text-sm text-base-content/60 line-clamp-3 grow">
                            {{ desc|length > 120 ? desc|slice(0, 120) ~ '...' : desc }}
                        </p>

                        {% if resource.categories is not empty %}
                        <div class="flex flex-wrap gap-1 mt-3">
                            {% for cat in resource.categories %}
                                <span class="badge badge-ghost badge-sm">{{ cat.name }}</span>
                            {% endfor %}
                        </div>
                        {% endif %}

                        <div class="card-actions mt-4">
                            <a href="{{ path('app_resource_show', { id: resource.id }) }}"
                               class="btn btn-primary btn-sm w-full">
                                Consulter
                            </a>
                        </div>

                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}

    {# ── Favoris (connecté uniquement) ────────────────────────────────────── #}
    {% if app.user %}
    <section class="mt-14">
        <h2 class="text-2xl font-bold mb-4">Mes articles favoris</h2>
        <div id="flash-favorites" aria-live="polite"></div>
        <div id="favorites-list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <p class="text-base-content/50 text-sm">Chargement...</p>
        </div>
    </section>

    <script>
    function loadFavorites() {
        fetch('/favorites/list')
            .then(r => r.json())
            .then(favorites => {
                const container = document.getElementById('favorites-list');
                if (favorites.length === 0) {
                    container.innerHTML = '<p class="text-base-content/50 text-sm">Vous n\'avez pas encore de favoris.</p>';
                    return;
                }
                container.innerHTML = favorites.map(f => `
                    <div class="card bg-base-100 shadow-sm" id="fav-card-${f.id}">
                        <div class="card-body">
                            <h3 class="card-title text-base">${f.title}</h3>
                            <p class="text-xs text-base-content/50">Ajouté le ${f.createdAt}</p>
                            <div class="card-actions justify-end mt-3 gap-2">
                                <a href="/resources/${f.id}" class="btn btn-primary btn-sm w-full">Consulter</a>
                                <button onclick="removeFavorite(${f.id})" class="btn btn-error btn-outline btn-sm w-full">Retirer</button>
                            </div>
                        </div>
                    </div>
                `).join('');
            });
    }

    function removeFavorite(articleId) {
        fetch(`/favorites/toggle/${articleId}`, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.json())
        .then(data => {
            if (data.status === 'removed') {
                document.getElementById(`fav-card-${articleId}`)?.remove();

                const flash = document.getElementById('flash-favorites');
                flash.innerHTML = '<div role="alert" class="alert alert-success text-sm">✅ Ressource retirée des favoris.</div>';
                setTimeout(() => flash.innerHTML = '', 3000);

                if (document.querySelectorAll('#favorites-list .card').length === 0) {
                    document.getElementById('favorites-list').innerHTML = '<p class="text-base-content/50 text-sm">Vous n\'avez pas encore de favoris.</p>';
                }
            }
        });
    }

    loadFavorites();
    </script>
    {% endif %}

</div>
</div>
{% endblock %}
