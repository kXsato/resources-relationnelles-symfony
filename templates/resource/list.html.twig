{% extends 'base.html.twig' %}

{% block title %}Ressources{% endblock %}

{% block body %}
<div class="container mt-5">

    <header class="mb-5 text-center">
        <h1 class="display-5 fw-bold">Découvrez nos ressources</h1>
        <p class="text-muted fs-5">Articles et contenus pour enrichir vos relations</p>
    </header>

    <div class="d-flex flex-wrap gap-2 justify-content-center mb-4">
        <a href="{{ path('app_resource_list') }}"
           class="btn btn-sm {{ currentCategoryId is null ? 'btn-primary' : 'btn-outline-primary' }}">
            Toutes
        </a>
        {% for category in categories %}
            <a href="{{ path('app_resource_list', { category: category.id }) }}"
               class="btn btn-sm {{ currentCategoryId == category.id ? 'btn-primary' : 'btn-outline-primary' }}">
                {{ category.name }}
            </a>
        {% endfor %}
    </div>

    {% if resources is empty %}
        <div class="text-center py-5">
            <p class="text-muted fs-5">Aucune ressource n'est disponible pour le moment.</p>
        </div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for resource in resources %}
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                {% set type = resource.resourceType %}
                                {% if type == 'article' %}
                                    <span class="badge bg-primary">📄 Article</span>
                                {% elseif type == 'video' %}
                                    <span class="badge bg-danger">🎬 Vidéo</span>
                                {% elseif type == 'game' %}
                                    <span class="badge bg-success">🎮 Jeu</span>
                                {% else %}
                                    <span class="badge bg-secondary">{{ type|capitalize }}</span>
                                {% endif %}
                                <small class="text-muted">{{ resource.createdAt|date('d/m/Y') }}</small>
                            </div>

                            <h5 class="card-title fw-semibold">{{ resource.title }}</h5>
                            {% set desc = resource.description|default('Découvrez cette ressource !') %}
                            <p class="card-text text-muted">
                                {{ desc|length > 100 ? desc|slice(0, 100) ~ '...' : desc }}
                            </p>
                        </div>

                        <div class="card-footer bg-transparent border-top-0 pb-3">
                            <a href="{{ path('app_resource_show', { id: resource.id }) }}" class="btn btn-primary w-100">
                                Consulter
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {% if app.user %}
    <section class="mt-5">
        <h2 class="fw-bold mb-3">Mes articles favoris</h2>
        <div id="flash-favorites"></div>
        <div id="favorites-list" class="row row-cols-1 row-cols-md-3 g-3">
            <p class="text-muted">Chargement...</p>
        </div>
    </section>

    <script>
    function loadFavorites() {
        fetch('/favorites/list')
            .then(r => r.json())
            .then(favorites => {
                const container = document.getElementById('favorites-list');
                if (favorites.length === 0) {
                    container.innerHTML = '<p class="text-muted">Vous n\'avez pas encore de favoris.</p>';
                    return;
                }
                container.innerHTML = favorites.map(f => `
                    <div class="col" id="fav-card-${f.id}">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body">
                                <h5 class="card-title">${f.title}</h5>
                                <small class="text-muted">Ajouté le ${f.createdAt}</small>
                            </div>
                            <div class="card-footer bg-transparent border-0 d-flex gap-2">
                                <a href="/resources/${f.id}" class="btn btn-primary w-100">Consulter</a>
                                <button onclick="removeFavorite(${f.id})" class="btn btn-danger w-100">Retirer</button>
                            </div>
                        </div>
                    </div>
                `).join('');
            });
    }

    function removeFavorite(articleId) {
        fetch(`/favorites/toggle/${articleId}`, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.json())
        .then(data => {
            if (data.status === 'removed') {
                document.getElementById(`fav-card-${articleId}`)?.remove();

                const flash = document.getElementById('flash-favorites');
                flash.innerHTML = '<div class="alert alert-success">✅ Ressource retirée des favoris.</div>';
                setTimeout(() => flash.innerHTML = '', 3000);

                if (document.querySelectorAll('#favorites-list .col').length === 0) {
                    document.getElementById('favorites-list').innerHTML = '<p class="text-muted">Vous n\'avez pas encore de favoris.</p>';
                }
            }
        });
    }

    loadFavorites();
    </script>
    {% endif %}

</div>
{% endblock %}