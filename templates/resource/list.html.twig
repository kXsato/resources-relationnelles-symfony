{% extends 'base.html.twig' %}

{% block title %}Ressources{% endblock %}

{% block body %}
<div class="flex flex-col w-full">

{# ── Breadcrumbs ──────────────────────────────────────────────────────────── #}
<nav aria-label="Fil d'Ariane" class="container mx-auto px-4 pt-4">
    <div class="breadcrumbs text-sm">
        <ul>
            <li><a href="/">Accueil</a></li>
            <li aria-current="page">Ressources</li>
        </ul>
    </div>
</nav>

{# ── Header ───────────────────────────────────────────────────────────────── #}
<header class="bg-base-200 py-10 text-center">
    <h1 class="text-3xl sm:text-4xl font-bold mb-2">Découvrez nos ressources</h1>
    <p class="text-base-content/60 text-sm sm:text-base">Articles et contenus pour enrichir vos relations</p>
</header>

<div class="container mx-auto px-4 py-6">

    {# ── Filtre par type ───────────────────────────────────────────────────── #}
    <nav aria-label="Filtrer par type" class="flex flex-wrap gap-2 justify-center mb-4">
        <a href="{{ path('app_resource_list', currentCategoryId ? { category: currentCategoryId } : {}) }}"
           class="btn btn-sm {{ currentType is null ? 'btn-primary' : 'btn-ghost' }}">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            Tout
        </a>
        <a href="{{ path('app_resource_list', { type: 'article' }|merge(currentCategoryId ? { category: currentCategoryId } : {})) }}"
           class="btn btn-sm {{ currentType == 'article' ? 'btn-primary' : 'btn-ghost' }}">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            Articles
        </a>
        <a href="{{ path('app_resource_list', { type: 'activity' }|merge(currentCategoryId ? { category: currentCategoryId } : {})) }}"
           class="btn btn-sm {{ currentType == 'activity' ? 'btn-primary' : 'btn-ghost' }}">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Activités
        </a>
    </nav>

    {# ── Filtres par catégorie ─────────────────────────────────────────────── #}
    <nav aria-label="Filtrer par catégorie" class="flex flex-wrap gap-2 justify-center mb-8">
        <a href="{{ path('app_resource_list', currentType ? { type: currentType } : {}) }}"
           class="badge badge-lg {{ currentCategoryId is null ? 'badge-primary' : 'badge-neutral badge-outline' }}"
           {% if currentCategoryId is null %}aria-current="true"{% endif %}>
            Toutes
        </a>
        {% for category in categories %}
            <a href="{{ path('app_resource_list', { category: category.id }|merge(currentType ? { type: currentType } : {})) }}"
               class="badge badge-lg {{ currentCategoryId == category.id ? 'badge-primary' : 'badge-neutral badge-outline' }}"
               {% if currentCategoryId == category.id %}aria-current="true"{% endif %}>
                {{ category.name }}
            </a>
        {% endfor %}
    </nav>

    {# ── Grille de cards ───────────────────────────────────────────────────── #}
    {% if resources is empty %}
        <div class="text-center py-16">
            <p class="text-base-content/50 text-lg">Aucune ressource n'est disponible pour le moment.</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for resource in resources %}
                <article class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow h-full">
                    <div class="card-body flex flex-col">

                        <div class="flex items-center justify-between mb-2">
                            {% set type = resource.resourceType %}
                            {% if type == 'article' %}
                                <span class="badge badge-primary badge-sm gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                                    Article
                                </span>
                            {% elseif type == 'activity' %}
                                <span class="badge badge-secondary badge-sm gap-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                                    Activité
                                </span>
                            {% else %}
                                <span class="badge badge-neutral badge-sm">{{ type|capitalize }}</span>
                            {% endif %}
                            <time class="text-xs text-base-content/40" datetime="{{ resource.createdAt|date('Y-m-d') }}">
                                {{ resource.createdAt|date('d/m/Y') }}
                            </time>
                        </div>

                        <h2 class="font-semibold leading-snug line-clamp-2 mb-2">
                            {{ resource.title }}
                        </h2>

                        {% set desc = resource.description|default('Découvrez cette ressource !') %}
                        <p class="text-sm text-base-content/60 line-clamp-3 grow">
                            {{ desc|length > 120 ? desc|slice(0, 120) ~ '...' : desc }}
                        </p>

                        {% if resource.categories is not empty %}
                        <div class="flex flex-wrap gap-1 mt-3">
                            {% for cat in resource.categories %}
                                <span class="badge badge-ghost badge-sm">{{ cat.name }}</span>
                            {% endfor %}
                        </div>
                        {% endif %}

                        <div class="card-actions mt-4">
                            <a href="{{ path('app_resource_show', { id: resource.id }) }}"
                               class="btn btn-primary btn-sm w-full">
                                Consulter
                            </a>
                        </div>

                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}

    {# ── Favoris (connecté uniquement) ────────────────────────────────────── #}
    {% if app.user %}
    <section class="mt-14">
        <h2 class="text-2xl font-bold mb-4">Mes favoris</h2>
        <div id="flash-favorites" aria-live="polite"></div>
        <div id="favorites-list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <p class="text-base-content/50 text-sm">Chargement...</p>
        </div>
    </section>

    <script>
    function loadFavorites() {
        fetch('/favorites/list')
            .then(r => r.json())
            .then(favorites => {
                const container = document.getElementById('favorites-list');
                if (favorites.length === 0) {
                    container.innerHTML = '<p class="text-base-content/50 text-sm">Vous n\'avez pas encore de favoris.</p>';
                    return;
                }
                container.innerHTML = favorites.map(f => `
                    <div class="card bg-base-100 shadow-sm" id="fav-card-${f.id}">
                        <div class="card-body">
                            <h3 class="card-title text-base">${f.title}</h3>
                            <p class="text-xs text-base-content/50">Ajouté le ${f.createdAt}</p>
                            <div class="card-actions justify-end mt-3 gap-2">
                                <a href="/resources/${f.id}" class="btn btn-primary btn-sm w-full">Consulter</a>
                                <button onclick="removeFavorite(${f.id})" class="btn btn-error btn-outline btn-sm w-full">Retirer</button>
                            </div>
                        </div>
                    </div>
                `).join('');
            });
    }

    function removeFavorite(articleId) {
        fetch(`/favorites/toggle/${articleId}`, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.json())
        .then(data => {
            if (data.status === 'removed') {
                document.getElementById(`fav-card-${articleId}`)?.remove();

                const flash = document.getElementById('flash-favorites');
                flash.innerHTML = '<div role="alert" class="alert alert-success text-sm"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Ressource retirée des favoris.</div>';
                setTimeout(() => flash.innerHTML = '', 3000);

                if (document.querySelectorAll('#favorites-list .card').length === 0) {
                    document.getElementById('favorites-list').innerHTML = '<p class="text-base-content/50 text-sm">Vous n\'avez pas encore de favoris.</p>';
                }
            }
        });
    }

    loadFavorites();
    </script>
    {% endif %}

</div>
</div>
{% endblock %}
