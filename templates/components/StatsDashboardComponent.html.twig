{% set stats = this.globalStats %}

<div {{ attributes }}>

    {# ── Sélecteur de période ─────────────────────────────────────────── #}
    <div style="display:flex;gap:0.5rem;margin-bottom:1.5rem;">
        {% for period in [7, 30, 90] %}
            <button
                type="button"
                data-action="live#action"
                data-live-action-param="setPeriod"
                data-live-action-days-param="{{ period }}"
                style="
                    padding:0.375rem 0.875rem;
                    border-radius:0.375rem;
                    border:1px solid #D1D5DB;
                    cursor:pointer;
                    font-size:0.8rem;
                    font-weight:500;
                    background:{{ days == period ? '#4F46E5' : '#fff' }};
                    color:{{ days == period ? '#fff' : '#374151' }};
                "
            >{{ period }}j</button>
        {% endfor %}
    </div>

    {# ── Cartes globales ──────────────────────────────────────────────── #}
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin-bottom:2rem;">

        <div style="background:#fff;border-radius:0.75rem;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
            <p style="margin:0;font-size:0.75rem;color:#6B7280;text-transform:uppercase;letter-spacing:.05em;">Utilisateurs</p>
            <p style="margin:0.25rem 0 0;font-size:1.75rem;font-weight:700;color:#111827;">{{ stats.users.total }}</p>
            <p style="margin:0.25rem 0 0;font-size:0.75rem;color:#6B7280;">
                {{ stats.users.active }} actifs · {{ stats.users.inactive }} inactifs
            </p>
            {% if stats.users.reactivationRequests > 0 %}
                <p style="margin:0.5rem 0 0;font-size:0.75rem;color:#D97706;font-weight:500;">
                    ⚠ {{ stats.users.reactivationRequests }} demande(s) de réactivation
                </p>
            {% endif %}
        </div>

        <div style="background:#fff;border-radius:0.75rem;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
            <p style="margin:0;font-size:0.75rem;color:#6B7280;text-transform:uppercase;letter-spacing:.05em;">Ressources</p>
            <p style="margin:0.25rem 0 0;font-size:1.75rem;font-weight:700;color:#111827;">{{ stats.resources.total }}</p>
            <div style="margin-top:0.25rem;">
                {% for status, count in stats.resources.byStatus %}
                    <span style="font-size:0.7rem;color:#6B7280;">{{ status }}: {{ count }}</span><br>
                {% endfor %}
            </div>
        </div>

        <div style="background:#fff;border-radius:0.75rem;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
            <p style="margin:0;font-size:0.75rem;color:#6B7280;text-transform:uppercase;letter-spacing:.05em;">Lectures</p>
            <p style="margin:0.25rem 0 0;font-size:1.75rem;font-weight:700;color:#111827;">{{ stats.progress.total }}</p>
            <div style="margin-top:0.25rem;">
                {% for status, count in stats.progress.byStatus %}
                    <span style="font-size:0.7rem;color:#6B7280;">{{ status }}: {{ count }}</span><br>
                {% endfor %}
            </div>
        </div>

        <div style="background:#fff;border-radius:0.75rem;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
            <p style="margin:0;font-size:0.75rem;color:#6B7280;text-transform:uppercase;letter-spacing:.05em;">Favoris</p>
            <p style="margin:0.25rem 0 0;font-size:1.75rem;font-weight:700;color:#111827;">{{ stats.favorites.total }}</p>
        </div>

    </div>

    {# ── Tableaux détaillés ───────────────────────────────────────────── #}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;">

        {# Top ressources lues #}
        <div style="background:#fff;border-radius:0.75rem;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
            <h4 style="margin:0 0 1rem;font-size:0.875rem;font-weight:600;color:#374151;">Top ressources lues</h4>
            <table style="width:100%;border-collapse:collapse;font-size:0.8rem;">
                <thead>
                    <tr style="color:#6B7280;text-align:left;">
                        <th style="padding-bottom:0.5rem;">Ressource</th>
                        <th style="padding-bottom:0.5rem;text-align:right;">Lecteurs</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in this.mostReadResources %}
                        <tr style="border-top:1px solid #F3F4F6;">
                            <td style="padding:0.4rem 0;color:#374151;">{{ row.title }}</td>
                            <td style="padding:0.4rem 0;text-align:right;font-weight:600;color:#4F46E5;">{{ row.readers }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="2" style="color:#9CA3AF;padding-top:0.5rem;">Aucune donnée</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# Progression moyenne par ressource #}
        <div style="background:#fff;border-radius:0.75rem;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
            <h4 style="margin:0 0 1rem;font-size:0.875rem;font-weight:600;color:#374151;">Progression moyenne par ressource</h4>
            <table style="width:100%;border-collapse:collapse;font-size:0.8rem;">
                <thead>
                    <tr style="color:#6B7280;text-align:left;">
                        <th style="padding-bottom:0.5rem;">Ressource</th>
                        <th style="padding-bottom:0.5rem;text-align:right;">Moy. %</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in this.averageReadingProgressPerResource %}
                        <tr style="border-top:1px solid #F3F4F6;">
                            <td style="padding:0.4rem 0;color:#374151;">{{ row.title }}</td>
                            <td style="padding:0.4rem 0;text-align:right;font-weight:600;color:#059669;">{{ row.avgPercentage|number_format(1) }}%</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="2" style="color:#9CA3AF;padding-top:0.5rem;">Aucune donnée</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# Top articles favoris #}
        <div style="background:#fff;border-radius:0.75rem;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
            <h4 style="margin:0 0 1rem;font-size:0.875rem;font-weight:600;color:#374151;">Articles les plus mis en favoris</h4>
            <table style="width:100%;border-collapse:collapse;font-size:0.8rem;">
                <thead>
                    <tr style="color:#6B7280;text-align:left;">
                        <th style="padding-bottom:0.5rem;">Article</th>
                        <th style="padding-bottom:0.5rem;text-align:right;">Favoris</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in this.topFavoritedArticles %}
                        <tr style="border-top:1px solid #F3F4F6;">
                            <td style="padding:0.4rem 0;color:#374151;">{{ row.title }}</td>
                            <td style="padding:0.4rem 0;text-align:right;font-weight:600;color:#D97706;">{{ row.total }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="2" style="color:#9CA3AF;padding-top:0.5rem;">Aucune donnée</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# Ressources par catégorie #}
        <div style="background:#fff;border-radius:0.75rem;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
            <h4 style="margin:0 0 1rem;font-size:0.875rem;font-weight:600;color:#374151;">Ressources publiées par catégorie</h4>
            <table style="width:100%;border-collapse:collapse;font-size:0.8rem;">
                <thead>
                    <tr style="color:#6B7280;text-align:left;">
                        <th style="padding-bottom:0.5rem;">Catégorie</th>
                        <th style="padding-bottom:0.5rem;text-align:right;">Ressources</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in this.resourcesByCategoryStats %}
                        <tr style="border-top:1px solid #F3F4F6;">
                            <td style="padding:0.4rem 0;color:#374151;">{{ row.categoryName }}</td>
                            <td style="padding:0.4rem 0;text-align:right;font-weight:600;color:#374151;">{{ row.total }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="2" style="color:#9CA3AF;padding-top:0.5rem;">Aucune donnée</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

    </div>

    {# ── Activité sur la période sélectionnée ─────────────────────────── #}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:1.5rem;">

        <div style="background:#fff;border-radius:0.75rem;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
            <h4 style="margin:0 0 1rem;font-size:0.875rem;font-weight:600;color:#374151;">
                Nouveaux inscrits ({{ days }}j)
            </h4>
            {% set newUsers = this.newUsersPerDay %}
            {% if newUsers is empty %}
                <p style="color:#9CA3AF;font-size:0.8rem;">Aucune inscription sur cette période.</p>
            {% else %}
                <p style="font-size:1.5rem;font-weight:700;color:#4F46E5;">
                    {{ newUsers|reduce((carry, row) => carry + row.total, 0) }}
                </p>
                <p style="font-size:0.75rem;color:#6B7280;margin-top:0.25rem;">inscriptions en {{ days }} jours</p>
            {% endif %}
        </div>

        <div style="background:#fff;border-radius:0.75rem;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
            <h4 style="margin:0 0 1rem;font-size:0.875rem;font-weight:600;color:#374151;">
                Ressources publiées ({{ days }}j)
            </h4>
            {% set newResources = this.publishedResourcesPerDay %}
            {% if newResources is empty %}
                <p style="color:#9CA3AF;font-size:0.8rem;">Aucune publication sur cette période.</p>
            {% else %}
                <p style="font-size:1.5rem;font-weight:700;color:#059669;">
                    {{ newResources|reduce((carry, row) => carry + row.total, 0) }}
                </p>
                <p style="font-size:0.75rem;color:#6B7280;margin-top:0.25rem;">ressources publiées en {{ days }} jours</p>
            {% endif %}
        </div>

    </div>

</div>
