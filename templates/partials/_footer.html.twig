<footer class="footer footer-horizontal footer-center bg-base-200 text-base-content rounded p-10">
    <nav class="grid grid-flow-col gap-4">
        <a href="{{ path('app_resource_list') }}" class="link link-hover">Ressources</a>
        <a href="{{ path('app_login') }}" class="link link-hover">Connexion</a>
        <a href="{{ path('app_register') }}" class="link link-hover">Inscription</a>
    </nav>
    <nav>
        <button onclick="copyUrl()" class="btn btn-outline btn-sm gap-2">
            <img src="https://cdn-icons-png.flaticon.com/512/11940/11940163.png"
                alt="copier"
                class="w-4 h-4">
            Partager cette page
        </button>
        <span id="copy-confirm" class="text-success text-sm ml-2" style="display:none">✅ Lien copié !</span>
    </nav>
    <aside>
        <p>Copyright © {{ "now"|date("Y") }} - Ressources Relationnelles</p>
    </aside>
</footer>

<script>
function copyUrl() {
    navigator.clipboard.writeText(window.location.href).then(() => {
        const confirm = document.getElementById('copy-confirm');
        confirm.style.display = 'inline';
        setTimeout(() => confirm.style.display = 'none', 2000);
    });
}
</script>