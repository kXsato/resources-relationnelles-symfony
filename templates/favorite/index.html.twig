{% extends 'base.html.twig' %}

{% block title %}Mes favoris{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="fw-bold mb-4">Mes favoris</h1>

    {% if favorites is empty %}
        <p class="text-muted">Vous n'avez pas encore de favoris.</p>
    {% else %}
        <div class="row row-cols-1 row-cols-md-3 g-4" id="favorites-list">
            {% for favorite in favorites %}
                <div class="col" id="fav-card-{{ favorite.article.id }}">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h5 class="card-title">{{ favorite.article.title }}</h5>
                            <small class="text-muted">Ajouté le {{ favorite.createdAt|date('d/m/Y') }}</small>
                        </div>
                        <div class="card-footer bg-transparent border-0 d-flex gap-2">
                            <a href="{{ path('app_resource_show', { id: favorite.article.id }) }}" class="btn btn-primary w-100">Consulter</a>
                            <button onclick="removeFavorite({{ favorite.article.id }})" class="btn btn-danger w-100">Retirer</button>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <div id="flash-favorites" class="mt-3"></div>
</div>

<script>
function removeFavorite(articleId) {
    fetch(`/favorites/toggle/${articleId}`, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'removed') {
            document.getElementById(`fav-card-${articleId}`)?.remove();
            const flash = document.getElementById('flash-favorites');
            flash.innerHTML = '<div class="alert alert-success">Ressource retirée des favoris.</div>';
            setTimeout(() => flash.innerHTML = '', 3000);
        }
    });
}
</script>
{% endblock %}